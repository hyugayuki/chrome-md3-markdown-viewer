{
  "manifest_version": 3,
  "name": "MD3 Markdown Viewer",
  "version": "1.0.0",
  "description": "ChromeでローカルのMarkdownファイルを開いた際、Material Design 3 (MD3) 準拠の美しい表示に変換します。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "file:///*/*.md",
        "file:///*/*.MD",
        "file:///*/*.markdown"
      ],
      "js": [
        "marked.min.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_end"
    }
  ]
}
